# --- OpenSky OAuth2 (client-credentials) ---
# Create an API client at https://opensky-network.org/ -> Account -> "API client".
# Basic auth (username/password) was removed in March 2026; these are required.
OPENSKY_CLIENT_ID=your_client_id
OPENSKY_CLIENT_SECRET=your_client_secret
OPENSKY_TOKEN_URL=https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token
OPENSKY_STATES_URL=https://opensky-network.org/api/states/all

# --- Bounding box (a single busy region; cost scales with area) ---
# lamin,lomin,lamax,lomax  -- example below is central Europe.
BBOX_LAMIN=47.0
BBOX_LOMIN=5.0
BBOX_LAMAX=55.0
BBOX_LOMAX=15.0

# --- Collector ---
POLL_INTERVAL_SECONDS=8

# --- Database ---
# Host port the Postgres container publishes on. Override if 5432 is already taken
# locally (e.g. a host PostgreSQL install) — and keep DATABASE_URL's port in sync.
DB_HOST_PORT=5432
DATABASE_URL=postgresql+asyncpg://skywatch:skywatch@localhost:5432/skywatch
